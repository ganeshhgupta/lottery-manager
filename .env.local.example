# Required: A random 32+ character string for signing session cookies
SESSION_SECRET=your-32-character-secret-key-here-change-me

# Required for Google Sheets backup: paste the full JSON key of your Google service account
# Get this from Google Cloud Console > IAM & Admin > Service Accounts > Create Key > JSON
# Then share your Google Sheet with the service account email (found in this JSON as "client_email")
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-sa@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
